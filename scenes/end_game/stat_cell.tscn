[gd_scene format=3]

; P14-3 終局統計表的儲存格／圖表文字標籤。end_game.gd `_add_cell`（表格）與
; `_mk_label`（圖表刻度）共用；instantiate 後由程式填 text／字級／字色／幾何。
; 本檔管的是共通樣式：黑描邊（覆蓋任何底色皆可讀）與不吃滑鼠事件。
[node name="StatCell" type="Label"]
mouse_filter = 2
theme_override_colors/font_color = Color(0.93, 0.94, 0.96, 1)
theme_override_colors/font_outline_color = Color(0, 0, 0, 0.9)
theme_override_constants/outline_size = 4
theme_override_font_sizes/font_size = 13
